name": "min_residuals", "argument": "min_residuals", "type": "float", "label": "Minimum absolute distance a value must be apart from its context windows expectation, in order for the Z scoring test to be applied", "help": "", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": null, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "min_periods", "argument": "min_periods", "type": "integer", "label": "Minimum number of valid observations that is required to be contained in a values context window, in order for the Z scoring test to be applied", "help": "", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "center", "argument": "center", "type": "boolean", "label": "If ``True`` (default), the tested value is centered in its context window; otherwise", "help": "it is the window\u2019s last value", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "true", "falsevalue": "false"}, {"model_class": "IntegerToolParameter", "name": "axis", "argument": "axis", "type": "integer", "label": "Axis along which to compute scores:", "help": "* ``0`` (default) \u2014 compute along the time axis only (separate windows for all fields). * ``1`` \u2014 compute along time and data axis (windows are 2 dimensional and span over all fields)", "help_format": "html", "refresh_on_change": false, "min": 0, "max": 1, "optional": false, "hidden": false, "is_dynamic": false, "value": "0", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "flag", "argument": "flag", "type": "float", "label": "The flag value the function uses to mark observations", "help": "Defaults to the ``BAD`` value of the trans