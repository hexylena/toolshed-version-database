", "discover_datasets": []}, {"model_class": "ToolOutput", "name": "marker_out", "format": "tabular", "label": "${tool.name} on ${on_string}: Markers", "hidden": false, "output_type": "data", "format_source": null, "default_identifier_source": "None", "metadata_source": null, "parent": null, "count": 1, "from_work_dir": "marker.tsv", "edam_format": "format_3475", "edam_data": "data_0006", "discover_datasets": []}], "panel_section_id": "single-cell", "panel_section_name": "Single-cell", "form_style": "regular"}