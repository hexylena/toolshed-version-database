{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/proteinortho_clustering/proteinortho_clustering/6.3.6+galaxy0", "name": "Proteinortho clustering", "version": "6.3.6+galaxy0", "description": "Spectral partitioning algorithm", "labels": [], "icon": null, "edam_operations": ["operation_3663"], "edam_topics": ["topic_0084"], "hidden": "", "is_workflow_compatible": true, "xrefs": [{"value": "proteinortho", "type": "bio.tools"}], "tool_shed_repository": {"name": "proteinortho_clustering", "owner": "iuc", "changeset_revision": "0be284f6abf4", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "blastgraph", "argument": null, "type": "data", "label": "Proteinortho blastgraph file (RBH) or a undirected weighted graph file in ABC format (needs -abc)", "help": "", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["tabular"], "edam": {"edam_formats": ["format_3475"], "edam_data": ["data_0006"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "FloatToolParameter", "name": "conn", "argument": "-conn", "type": "float", "label": "Minimal connectivity (-conn)", "help": "Split if algebraic connectivity is below this value.", "help_format": "html", "refresh_on_change": false, "min": null, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.1", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "minspecies", "argument": "minspecies", "type": "float", "label": "Min species ratio (-minspecies)", "help": "Stop clustering if the ratio of species per nodes in a cluster is below this value. Trumps the conn threshold.", "help_format": "html", "refresh_on_change": false, "min": null, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "1.0", "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "core", "argument": "-core", "type": "boolean", "label": "Enable core mode", "help": "Only split a cluster if all species are preserved in the resulting clusters. Disables the conn and minspecies thresholds.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "-core", "falsevalue": ""}, {"model_class": "BooleanToolParameter", "name": "abc", "argument": "-abc", "type": "boolean", "label": "Input is ABC format", "help": "Use this if your graph file is in abc format (node1(tab)node2(tab)pos.weight). The graph is expected to be unweighted (if the edge a-b is present, b-a is ignored).", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "-abc", "falsevalue": ""}, {"model_class": "IntegerToolParameter", "name": "seed", "argument": "-seed", "type": "integer", "label": "Random seed (-seed)", "help": "Set srand seed for reproducibility.", "help_format": "html", "refresh_on_change": false, "min": null, "max": null, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "SelectToolParameter", "name": "lapack", "argument": "-lapack", "type": "select", "label": "Use LAPACK ssyevr for algebraic connectivity calculation", "help": "", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": "1", "options": [["Use power iteration instead of LAPACK", "0", false], ["Yes, if applicable", "1", true], ["Always", "2", false]], "display": null, "multiple": false, "textable": false}], "outputs": [{"model_class": "ToolOutput", "name": "clustering", "format": "tabular", "label": "${tool.name} on ${on_string}: Clustering Result (conn=${conn})", "hidden": false, "output_type": "data", "format_source": null, "default_identifier_source": "None", "metadata_source": null, "parent": null, "count": 1, "from_work_dir": "output.tsv", "edam_format": "format_3475", "edam_data": "data_0006", "discover_datasets": []}], "panel_section_id": "proteomics", "panel_section_name": "Proteomics", "form_style": "regular"}