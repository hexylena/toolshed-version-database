at", "label": "Minimum density of predicted complexes.", "help": "Increase the minimum density if you get too many clusters and they seem too sparse, or decrease it if you are not getting enough clusters. ", "help_format": "html", "refresh_on_change": false, "min": 0.1, "max": 1.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.3", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "min_size", "argument": "--min-size", "type": "integer", "label": "Minimum size for the Viral Cluster.", "help": "Smaller clusters are discarded immediately.", "help_format": "html", "refresh_on_change": false, "min": 2, "max": 10, "optional": false, "hidden": false, "is_dynamic": false, "value": "2", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "vc_overlap", "argument": "--vc-overlap", "type": "float", "label": "Maximum allowed overlap between two clusters.", "help": "", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": 3.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.9", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "vc_penalty", "argument": "--vc-penalty", "type": "integer", "label": "Penalty value for the inclusion of each node in a cluster.", "help": "It can be used to model the possibility of uncharted connections for each node, so nodes with only a single weak connection to a cluster will not be added to the cluster as the penalty value will outweigh the benefits of adding the node.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": 10, "optional": false, "hidden": false, "is_dynamic": false, "value": "2", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "vc_haircut", "argument": "--vc-haircut", "type": "float", "label": "Apply a haircut transformation to remove dangling nodes from detected clusters.", "help": "", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": 1.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.55", "area": false, "datalist": []}, {"model_class": "SelectToolParameter", "name": "merge_method", "argument": "--merge-method", "type": "select", "label": "Method used to merge highly overlapping complexes.", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "single", "options": [["single", "single", false], ["multi", "multi", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "SelectToolParameter", "name": "similarity", "argument": "--similarity", "type": "select", "label": "Similarity function used in the merging step.", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "match", "options": [["match", "match", false], ["simpson", "simpson", false], ["jaccard", "jaccard", false], ["dice", "dice", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "SelectToolParameter", "name": "seed_method", "argument": "--seed-method", "type": "select", "label": "Seed generation method", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "nodes", "options": [["unused_nodes", "unused_nodes", false], ["nodes", "nodes", true], ["edges", "edges", false], ["cliques", "cliques", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "BooleanToolParameter", "name": "optimize", "argument": "--optimize", "type": "boolean", "label": "Optimize hierarchical distances during second-pass of the viral clusters.", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "--optimize", "falsevalue": ""}]}, {"model_class": "Section", "name": "network", "type": "section", "title": "Similarity network and module"