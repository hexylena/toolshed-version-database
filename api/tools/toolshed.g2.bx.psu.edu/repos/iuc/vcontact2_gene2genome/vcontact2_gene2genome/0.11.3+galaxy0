{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/vcontact2_gene2genome/vcontact2_gene2genome/0.11.3+galaxy0", "name": "vConTACT2 gene2genome", "version": "0.11.3+galaxy0", "description": "prepare gene to genome mappings from fasta headers", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "vcontact2_gene2genome", "owner": "iuc", "changeset_revision": "367c9c92ee19", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "proteins", "argument": null, "type": "data", "label": "Protein fasta file", "help": "Sequences for which to prepare mappings.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["fasta"], "edam": {"edam_formats": ["format_1929"], "edam_data": ["data_2044"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "TextToolParameter", "name": "pattern", "argument": null, "type": "text", "label": "Regex pattern to extract protein_id and contig_id", "help": "The pattern should have two nested capture groups. <br>The default pattern works for headers generated by Prodigal. For Phanotate genes use '^>((.*?)_CDS_[0-9]+) '.", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": "^>((.*?)_[0-9]+) #", "area": false, "datalist": [{"label": "/^>((.*?)_[0-9]+) #/ - Prodigal", "value": "^>((.*?)_[0-9]+) #"}, {"label": "/^>((.*?)_CDS_[0-9]+) / - Phanotate", "value": "^>((.*?)_CDS_[0-9]+) "}, {"label": "^>((.*?)-gene_[0-9]+)/ - VirSorter", "value": "^>((.*?)-gene_[0-9]+)"}]}, {"model_class": "DataToolParameter", "name": "bins", "argument": null, "type": "data", "label": "Bin membeship file", "help": "Replace the contig_ids with their corresponding bin, e.g. to process all contigs in a vMAG together."