{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/virulign/virulign/1.1.1+galaxy0", "name": "VIRULIGN", "version": "1.1.1+galaxy0", "description": "Codon-correct pairwise alignments.", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "virulign", "owner": "iuc", "changeset_revision": "0620360e441e", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "reference", "argument": null, "type": "data", "label": "Reference (FASTA or ORF\u2011description XML)", "help": "", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["fasta", "xml"], "edam": {"edam_formats": ["format_1929", "format_2332"], "edam_data": ["data_2044", "data_0006"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "DataToolParameter", "name": "sequences", "argument": null, "type": "data", "label": "FASTA sequences to align", "help": "", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["fasta"], "edam": {"edam_formats": ["format_1929"], "edam_data": ["data_2044"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "SelectToolParameter", "name": "exportKind", "argument": "--exportKind", "type": "select", "label": "Which type of output to generate:", "help": "Defines the output type of the alignment, either a FASTA alignment file or a CSV mutation file", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "GlobalAlignment", "options": [["GlobalAlignment", "GlobalAlignment", false], ["PairwiseAlignments", "PairwiseAlignments", false], ["PositionTable", "PositionTable", false], ["MutationTable", "MutationTable", false], ["Mutations", "Mutations", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "SelectToolParameter", "name": "exportAlphabet", "argument": "--exportAlphabet", "type": "select", "label": "Sequence alphabet", "help": "Defines the alphabet in which the alignment is generated.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "AminoAcids", "options": [["Amino acids", "AminoAcids", false], ["Nucleotides", "Nucleotides", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "BooleanToolParameter", "name": "exportWithInsertions", "argument": "--exportWithInsertions", "type": "boolean", "label": "Include insertions?", "help": "Determines whether insertions can be added to the reference sequence. The option 'yes' will insert gaps into the reference sequence to accommodate the identification of codon insertions in the target sequences. Option 'No' removes codon insertions in the reference sequence that were generated during the alignment procedure.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": true, "truevalue": "yes", "falsevalue": "no"}, {"model_class": "BooleanToolParameter", "name": "exportReferenceSequence", "argument": "--exportReferenceSequence", "type": "boolean", "label": "Add the reference sequence to output?", "help": "Controls whether the reference sequence is to be added to the alignment.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "yes", "falsevalue": "no"}, {"model_class": "FloatToolParameter", "name": "gapOpenPenalty", "argument": "--gapOpenPenalty", "type": "float", "label": "Gap open penalty", "help": "Defines the value of the penalty to start a new gap.", "help_format": "html", "refresh_on_change": false, "min": null, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "10.0", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "gapExtensionPenalty", "argument": "--gapExtensionPenalty", "type": "float", "label": "Gap extension penalty", "help": "Defines the value of the penalty to extend an existing gap.", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "3.3", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "maxFrameShifts", "argument": "--maxFrameShifts", "type": "integer", "label": "Maximum allowed frame shifts", "help": "Defines the maximum number of frame-shifts allowed.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "3", "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "nt_debug", "argument": "--nt-debug", "type": "boolean", "label": "Report failed sequences?", "help": "This parameter allows to visualise sequences that could not be aligned by VIRULIGN. When this option is used, pairwise sequence alignments of failed target sequences and the reference sequence will be reported. This feature allows to inspect each failed target sequence individually to understand why the target sequence did not pass the quality control of the alignment.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "yes", "falsevalue": "no"}], "outputs": [{"model_class": "ToolOutputCollection", "name": "failed_outputs", "format": null, "label": "${tool.name} on ${sequences.name}: Failed alignments", "hidden": false, "output_type": "collection", "default_format": "data", "default_format_source": null, "default_metadata_source": null, "inherit_format": false, "inherit_metadata": false, "structure": {"collection_type": "list", "collection_type_