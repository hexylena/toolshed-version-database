eter", "name": "overlap_penalty", "argument": "-q", "type": "float", "label": "Overlap penalty coefficient", "help": "Per-base penalty applied to overlaps when scoring a chain: an overlap of size O costs q*O.", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.1", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "score_drop", "argument": "-z", "type": "integer", "label": "Score drop threshold for breaking a chain", "help": "A chain is broken when its running score drops by more than this value.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "1000", "area": false, "datalist": []}]}, {"model_class": "Section", "name": "filter_params", "type": "section", "title": "Chain selection", "help": null, "expanded": false, "inputs": [{"model_class": "IntegerToolParameter", "name": "min_chain_score", "argument": "-s", "type": "integer", "label": "Minimum chain score", "help": "Chains whose score (C - G*p - O*q) is below this value are discarded.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "10000", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "min_chain_count", "argument": "-n", "type": "integer", "label": "Minimum number of alignment fragments per chain", "help": "Chains containing fewer alignment fragments than this are discarded.", "help_format": "html", "refresh_on_change": false, "min": 1, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "1", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "chain_coverage", "argument": "-c", "type": "float", "label": "Maximum chain coverage (fraction of chain size)", "help": "A chain is discarded if it is already covered by previously 