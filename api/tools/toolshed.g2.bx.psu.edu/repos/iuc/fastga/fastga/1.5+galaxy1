{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/fastga/fastga/1.5+galaxy1", "name": "FastGA", "version": "1.5+galaxy1", "description": "align whole genomes", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "versions": ["1.3.1+galaxy1", "1.5+galaxy0", "1.5+galaxy1"], "hidden_versions": [], "tool_shed_repository": {"name": "fastga", "owner": "iuc", "changeset_revision": "27d750de596d", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "input1", "argument": null, "type": "data", "label": "FASTA sequence 1", "help": "FASTA or gzip-compressed FASTA file of a high-quality genome assembly (Q40 or better). The order of inputs can affect results\u2014FastGA is not commutative unless symmetric seeding (-S) is enabled.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["fasta", "fasta.gz"], "edam": {"edam_formats": ["format_1929", "format_1929"], "edam_data": ["data_2044", "data_2044"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "DataToolParameter", "name": "input2", "argument": null, "type": "data", "label": "FASTA sequence 2", "help": "FASTA or gzip-compressed FASTA file of a high-quality genome assembly (Q40 or better). The order of inputs can affect results\u2014FastGA is not commutative unless symmetric seeding (-S) is enabled.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["fasta", "fasta.gz"], "edam": {"edam_formats": ["format_1929", "format_1929"], "edam_data": ["data_2044", "data_2044"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "BooleanToolParameter", "name": "disable_soft_mask", "argument": "-N", "type": "boolean", "label": "Do not soft mask", "help": "Ignore masking information encoded in the genome index. By default, masking from the GIX is applied during alignment to reduce spurious matches in repeat-rich regions.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "-N", "falsevalue": ""}, {"model_class": "BooleanToolParameter", "name": "use_sym_seeding", "argument": "-S", "type": "boolean", "label": "Use symmetric seeding", "help": "Generate seeds from both genomes instead of only from genome 1. Makes alignment results independent of input order at the cost of extra computation time. Generally not recommended for standard use.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "-S", "falsevalue": ""}, {"model_class": "IntegerToolParameter", "name": "adaptive_seed_count_cutoff", "argument": "-f", "type": "integer", "label": "Adaptive seed count cutoff", "help": "Frequency threshold for repetitive adaptive seeds (adaptamers). Seeds occurring more than this many times across both genomes are excluded from seeding to prevent anchoring in repetitive regions. Lower values are more stringent. Range: 0\u2013255.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": 255, "optional": false, "hidden": false, "is_dynamic": false, "value": "10", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "minimum_seed_coverage", "argument": "-c", "type": "integer", "label": "Minimum seed chain coverage in both genomes", "help": "Minimum base-pair span that a seed chain must cover in both genomes to be retained for alignment extension. Increasing this value reduces spurious short chains. Range: \u2265 0.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "85", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "new_seed_threshold", "argument": "-s", "type": "integer", "label": "Threshold for starting a new seed chain", "help": "Maximum gap (in bp) allowed between consecutive seeds within a chain. Seeds further apart than this threshold start a new independent chain. Increasing this allows chaining across larger gaps; decreasing it produces more, shorter chains. Range: \u2265 0.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "1000", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "minimum_alignment_length", "argument": "-l", "type": "integer", "label": "Minimum alignment length", "help": "Alignments shorter than this length (in bp) are discarded from the output. Increase to focus on longer syntenic blocks and reduce noise from short matches. Range: \u2265 0.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "100", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "minimum_alignment_identity", "argument": "-i", "type": "float", "label": "Minimum alignment identity", "help": "Minimum sequence identity fraction required to report an alignment. For example, 0.7 requires at least 70% identity. Lower values permit more divergent alignments. Range: 0.55\u2013<1.0.", "help_format": "html", "refresh_on_change": false, "min": 0.55, "max": 1.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.7", "area": false, "datalist": []}, {"model_class": "Conditional", "name": "chain_mode", "type": "conditional", "cases": [{"model_class": "ConditionalWhen", "value": "no", "inputs": []}, {"model_class": "ConditionalWhen", "value": "yes", "inputs": [{"model_class": "Section", "name": "chain_params", "type": "section", "title": "Chain construction and scoring", "help": null, "expanded": false, "inputs": [{"model_class": "IntegerToolParameter", "name": "max_gap", "argument": "-g", "type": "integer", "label": "Maximum gap size between consecutive alignments (bp)", "help": "Upper bound on the gap allowed between two consecutive alignments in a chain. Larger values join more distant alignments into a single chain.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "10000", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "max_overlap", "argument": "-l", "type": "integer", "label": "Maximum overlap size between consecutive alignments (bp)", "help": "Upper bound on how much two consecutive alignments in a chain may overlap.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "10000", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "gap_penalty", "argument": "-p", "type": "float", "label": "Gap penalty coefficient", "help": "Per-base penalty applied to gaps when scoring a chain: a gap of size G costs p*G.", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.1", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "overlap_penalty", "argument": "-q", "type": "float", "label": "Overlap penalty coefficient", "help": "Per-base penalty applied to overlaps when scoring a chain: an overlap of size O costs q*O.", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.1", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "score_drop", "argument": "-z", "type": "integer", "label": "Score drop threshold for breaking a chain", "help": "A chain is broken when its running score drops by more than this value.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "1000", "area": false, "datalist": []}]}, {"model_class": "Section", "name": "filter_params", "type": "section", "title": "Chain selection", "help": null, "expanded": false, "inputs": [{"model_class": "IntegerToolParameter", "name": "min_chain_score", "argument": "-s", "type": "integer", "label": "Minimum chain score", "help": "Chains whose score (C - G*p - O*q) is below this value are discarded.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "10000", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "min_chain_count", "argument": "-n", "type": "integer", "label": "Minimum number of alignment fragments per chain", "help": "Chains containing fewer alignment fragments than this are discarded.", "help_format": "html", "refresh_on_change": false, "min": 1, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "1", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "chain_coverage", "argument": "-c", "type": "float", "label": "Maximum chain coverage (fraction of chain size)", "help": "A chain is discarded if it is already covered by previously selected chains by more than this fraction of its own length.", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": 1.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.5", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "seq_coverage", "argument": "-e", "type": "float", "label": "Minimum extension (fraction of sequence size)", "help": "A chain must contribute new coverage of at least this fraction of the sequence length to be kept. 0 disables the filter.", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": 1.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.0", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "close_gap_limit", "argument": "-f", "type": "integer", "label": "Maximum gap for fuzzy merge (bp)", "help": "When tracking positions already covered by selected chains, gaps up to this size are treated as covered.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "1000", "area": false, "datalist": []}]}]}], "test_param": {"model_class": "SelectToolParameter", "name": "enabled", "argument": null, "type": "select", "label": "Chain alignments with ALNchain", "help": "Chaining post-processes the alignment into one-to-one global chains (allowing rearrangements), reducing spurious short hits. When enabled, FastGA internally produces a .1aln, runs ALNchain, and then converts the result back to the selected output format.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": "no", "options": [["No chaining", "no", true], ["Chain with ALNchain", "yes", false]], "display": null, "multiple": false, "textable": false}}, {"model_class": "Section", "name": "output_settings", "type": "section", "title": "Output", "help": null, "expanded": false, "inputs": [{"model_class": "Conditional", "name": "out", "type": "conditional", "cases": [{"model_class": "ConditionalWhen", "value": "-paf", "inputs": [{"model_class": "SelectToolParameter", "name": "cigar_string", "argument": null, "type": "select", "label": "Use CIGAR string?", "help": "Optionally add a CIGAR string to PAF output (column 17). With X's (-pafx): mismatches are encoded as 'X', matches as '='. With ='s (-pafm): all aligned bases encoded as 'M'. Only one CIGAR style can be selected.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "no", "options": [["No CIGAR string", "no", true], ["CIGAR string with X's (-pafx)", "-pafx", false], ["CIGAR string with ='s (-pafm)", "-pafm", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "SelectToolParameter", "name": "cs_string", "argument": null, "type": "select", "label": "Use CS string?", "help": "Optionally add a CS difference string to PAF output. Short form (-pafs): compact encoding using ':', '*', '+', '-' operators. Long form (-pafS): full nucleotide-level representation. Only one CS style can be selected.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "no", "options": [["No CS string", "no", true], ["CS string in short form (-pafs)", "-pafs", false], ["CS string in long form (-pafS)", "-pafS", false]], "display": null, "multiple": false, "textable": false}]}, {"model_class": "ConditionalWhen", "value": "-psl", "inputs": []}, {"model_class": "ConditionalWhen", "value": "-1:output", "inputs": []}], "test_param": {"model_class": "SelectToolParameter", "name": "format", "argument": null, "type": "select", "label": "Specify the output format", "help": "Output format for alignments. PAF (Pairwise Alignment Format) is the default and most widely supported. PSL (Pattern Space Layout) is compatible with UCSC tools. 1ALN is a compact binary ONEcode format\u2014note that 1ALN output is nondeterministic.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": "-paf", "options": [["paf (-paf)", "-paf", true], ["psl (-psl)", "-psl", false], ["1aln (-1)", "-1:output", false]], "display": null, "multiple": false, "textable": false}}]}], "outputs": [{"model_class": "ToolOutput", "name": "output", "format": "paf", "label": null, "hidden": false, "output_type": "data", "format_source": null, "default_identifier_source": "None", "metadata_source": null, "parent": null, "count": 1, "from_work_dir": null, "edam_format": "format_2330", "edam_data": "data_0006", "discover_datasets": []}], "panel_section_id": "mapping", "panel_section_name": "Mapping", "form_style": "regular"}