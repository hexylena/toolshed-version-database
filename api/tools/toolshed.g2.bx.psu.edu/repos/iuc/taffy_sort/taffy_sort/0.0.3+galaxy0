ic": false, "value": "false", "options": [["No, keep all rows (default)", "false", true], ["Yes, remove rows matching prefixes in a file (--filterFile)", "true", false]], "display": null, "multiple": false, "textable": false}}, {"model_class": "Conditional", "name": "duplicateFile", "type": "conditional", "cases": [{"model_class": "ConditionalWhen", "value": "false", "inputs": []}, {"model_class": "ConditionalWhen", "value": "true", "inputs": [{"model_class": "DataToolParameter", "name": "input_dup_file", "argument": null, "type": "data", "label": "Duplicate filter file", "help": "A text file where each line is a prefix of a sequence name. If multiple rows in a block match a prefix, only the first occurrence is kept", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["txt"], "edam": {"edam_formats": ["format_2330"], "edam_data": ["data_0006"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}]}], "test_param": {"model_class": "SelectToolParameter", "name": "value", "argument": null, "type": "select", "label": "Remove only duplicate rows", "help": "", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": "false", "options": [["No, keep duplicates (default)", "false", true], ["Yes, remove duplicates matching prefixes in a file (--dupFilterFile)", "true", false]], "display": null, "multiple": false, "textable": false}}]}, {"model_class": "Conditional", "name": "paddingFile", "type": "conditional", "cases": [{"model_class": "ConditionalWhen", "value": "false", "inputs": []}, {"model_class": "ConditionalWhen", "value": "true", "inputs": [{"model_class": "DataToolParameter", "name": "input_pad_file", "argument": null, "type": "data", "label": "Padding file", "help": "A text file where each line is a prefix of a sequence name. If an alignment block is missing a row matching a prefix, a