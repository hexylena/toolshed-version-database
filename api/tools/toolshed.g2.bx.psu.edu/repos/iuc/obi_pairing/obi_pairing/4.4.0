{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/obi_pairing/obi_pairing/4.4.0", "name": "obipairing", "version": "4.4.0", "description": "When DNA metabarcoding sequences are generated as paired reads on the Illumina platform, obipairing aims to align forward and reverse reads to generate full length amplicon sequences.", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "obi_pairing", "owner": "iuc", "changeset_revision": "82385545ce58", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataCollectionToolParameter", "name": "inputfastq", "argument": null, "type": "data_collection", "label": "Paired reads", "help": "file of 3p and 5p Illumina pair-end reads to assemble in fastq (sanger or solexa) nucleic format", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "collection_types": ["paired"], "fields": null, "column_definitions": null, "extensions": ["fastqsanger", "fastqsanger.gz", "fastqsolexa", "fastqsolexa.gz"], "multiple": false, "options": {"hda": [], "hdca": [], "dce": []}, "tag": null}, {"model_class": "FloatToolParameter", "name": "min_ident", "argument": null, "type": "float", "label": "minimum score for keeping aligment", "help": "", "help_format": "html", "refresh_on_change": false, "min": null, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.8", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "min_overlap", "argument": null, "type": "integer", "label": "minimum overlap, all the reads shorter than this value will be concatenated instead of aligned", "help": "", "help_format": "html", "refresh_on_change": false, "min": null, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "10", "area": false, "datalist": []}, {"model_class": "SelectToolParameter", "name": "alignement_mode", "argument": null, "type": "select", "label": "Select a mode of alignement", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "basic_mode", "options": [["Default", "basic_mode", true], ["Run an exact alignment algorithm based", "exact_mode", false], ["Compute absolute fast score", "fast_absolute", false]], "display": "radio", "multiple": false, "textable": false}, {"model_class": "BooleanToolParameter", "name": "compress_bool", "argument": null, "type": "boolean", "label": "Do you want to compress the output file ?", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "--compressed", "falsevalue": ""}], "outputs": [{"model_class": "ToolOutput", "name": "output", "format": "data", "label": null, "hidden": false, "output_type": "data", "format_source": "inputfastq", "default_identifier_source": "None", "metadata_source": null, "parent": null, "count": 1, "from_work_dir": null, "edam_format": "format_1915", "edam_data": "data_0006", "discover_datasets": []}], "panel_section_id": "dna_metabarcoding", "panel_section_name": "DNA Metabarcoding", "form_style": "regular"}