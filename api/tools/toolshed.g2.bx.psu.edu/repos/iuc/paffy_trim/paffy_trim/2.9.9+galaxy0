{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/paffy_trim/paffy_trim/3.1.4+galaxy0", "name": "Paffy trim", "version": "3.1.4+galaxy0", "description": "truncates the ends of PAF alignments", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "paffy_trim", "owner": "iuc", "changeset_revision": "b22e381a9a8e", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "input_paf", "argument": null, "type": "data", "label": "PAF file", "help": "", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["paf", "paf.gz"], "edam": {"edam_formats": ["format_2330", "format_2330"], "edam_data": ["data_0006", "data_0006"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "Conditional", "name": "trim", "type": "conditional", "cases": [{"model_class": "ConditionalWhen", "value": "true", "inputs": [{"model_class": "FloatToolParameter", "name": "trimIdentity", "argument": "--trimIdentity", "type": "float", "label": "Tolerance fraction", "help": "Trims alignment ends where the local sequence identity falls below a dynamic threshold. The threshold is based on the overall alignment identity (x) and this tolerance fraction (t), using the formula: x \u2212 (x * t). The final length trimmed is capped by the 'Max fraction to trim' value below", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": 1.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.05", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "trimFraction", "argument": "--trimFraction", "type": "float", "label": "Max fraction to trim", "help": "Max fraction to trim from each end of the alignment. This cap is calculated by multiplying the sum of aligned bases and