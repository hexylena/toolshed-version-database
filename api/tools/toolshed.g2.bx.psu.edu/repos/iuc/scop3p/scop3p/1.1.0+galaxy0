{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/scop3p/scop3p/1.1.0+galaxy0", "name": "Scop3P", "version": "1.1.0+galaxy0", "description": "fetches post-translational modifications (phospho-sites) from Scop3P database", "labels": [], "icon": null, "edam_operations": [], "edam_topics": ["topic_0121", "topic_0601", "topic_3047"], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "scop3p", "owner": "iuc", "changeset_revision": "e4cfb5adc31c", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "TextToolParameter", "name": "accession", "argument": null, "type": "text", "label": "UniProtKB Accession number", "help": "UniProtKB Accession numbers consist of 6 or 10 alphanumerical characters. Examples: O00571, P51532, Q14839, P54132", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "include_peptides", "argument": "--include-peptides", "type": "boolean", "label": "Include Phospho-peptides table", "help": "This table will show all available phospho-peptides identified by re-processing different phospho-proteome experiments for the particular protein of interest.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "true", "falsevalue": ""}, {"model_class": "BooleanToolParameter", "name": "include_structures", "argument": "--include-structures", "type": "boolean", "label": "Include Structures table", "help": "This table will list all available structures and the P-sites mapped onto the structure. By default the structures are ordered based on the number of P-sites they has and then by resolution.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "true", "falsevalue": ""}, {"model_c