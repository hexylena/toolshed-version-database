{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/faffy_chunk/faffy_chunk/3.1.4+galaxy0", "name": "Faffy chunk", "version": "3.1.4+galaxy0", "description": "breaks FASTA file(s) into smaller files", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "faffy_chunk", "owner": "iuc", "changeset_revision": "9f970dc94538", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "input_fasta", "argument": null, "type": "data", "label": "FASTA file(s)", "help": "", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["fasta", "fasta.gz", "fasta.bz2"], "edam": {"edam_formats": ["format_1929", "format_1929", "format_1929"], "edam_data": ["data_2044", "data_2044", "data_2044"]}, "multiple": true, "min": null, "max": null, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "IntegerToolParameter", "name": "chunkSize", "argument": "--chunkSize", "type": "integer", "label": "Chunk size (bp)", "help": "The target length of each chunk", "help_format": "html", "refresh_on_change": false, "min": 1, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "10000000", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "overlap", "argument": "--overlap", "type": "integer", "label": "Overlap size (bp)", "help": "Number of base pairs overlapping with the next chunk. Total output length will be chunkSize + overlapSize", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "100000", "area": false, "datalist": []}, {"model_class": "Conditional", "name": "compression", "type": "conditional", "cases": [{"model_class": "ConditionalWhen", "value": "", "inputs": []}, {"model_class