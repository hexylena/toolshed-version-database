ameter", "name": "colorBases", "argument": "--colorBases", "type": "boolean", "label": "Colorize bases", "help": "Adds color codes to the output for easier reading", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "--colorBases", "falsevalue": ""}, {"model_class": "BooleanToolParameter", "name": "omitCoordinates", "argument": "--omitCoordinates", "type": "boolean", "label": "Omit coordinates", "help": "Only outputs the alignment columns, omitting sequence coordinates", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "--omitCoordinates", "falsevalue": ""}]}, {"model_class": "SelectToolParameter", "name": "compression_taf", "argument": null, "type": "select", "label": "Compress output", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "none", "options": [["Don't compress output (default)", "none", true], ["Compress output to .gz", "gz", false]], "display": null, "multiple": false, "textable": false}]}, {"model_class": "ConditionalWhen", "value": "maf", "inputs": [{"model_class": "Section", "name": "visual", "type": "section", "title": "Visualization options", "help": "These options are for visualization only. They produce an invalid formatted output file, which cannot be used by most downstream tools", "expanded": true, "inputs": [{"model_class": "BooleanToolParameter", "name": "colorBases", "argument": "--colorBases", "type": "boolean", "label": "Colorize bases", "help": "Adds color codes to the output for easier reading", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "--colorBases", "falsevalue": ""}]}, {"model_class": "SelectToolParameter", "name": "compression_maf", "argument": null, "type": "select", "label": "Compress o