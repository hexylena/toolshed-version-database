{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/spatialdata_operation/spatialdata_operation/0.7.2+galaxy0", "name": "SpatialData Operations", "version": "0.7.2+galaxy0", "description": "perform operations on SpatialData objects", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "spatialdata_operation", "owner": "iuc", "changeset_revision": "2adfc39ffbac", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "input_spatialdata", "argument": null, "type": "data", "label": "SpatialData object", "help": "", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["spatialdata.zip"], "edam": {"edam_formats": ["format_2333"], "edam_data": ["data_0006"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "Conditional", "name": "operation_condi", "type": "conditional", "cases": [{"model_class": "ConditionalWhen", "value": "bounding_box_query", "inputs": [{"model_class": "TextToolParameter", "name": "axes", "argument": null, "type": "text", "label": "Axes", "help": "Comma-separated list of axes that min_coordinate and max_coordinate refer to (e.g., 'x,y' or 'x,y,z')", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": "x,y", "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "min_coordinate", "argument": null, "type": "text", "label": "Minimum coordinates", "help": "Comma-separated minimum coordinates along all dimensions (e.g., '0,0')", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "max_coordinate", "argument": null, "type": "text", "label": "Maximum coordinates", "help": "Comma-separated maximum coordinates along all dimensions (e.g., '100,100')", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "target_coordinate_system", "argument": null, "type": "text", "label": "Target coordinate system", "help": "The coordinate system the bounding box is defined in", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": "global", "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "filter_table_bool", "argument": null, "type": "boolean", "label": "Filter table?", "help": "If True, the table is filtered to only contain rows annotating regions within the bounding box", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": true, "truevalue": "True", "falsevalue": "False"}]}, {"model_class": "ConditionalWhen", "value": "polygon_query", "inputs": [{"model_class": "TextToolParameter", "name": "polygon_coords", "argument": null, "type": "text", "label": "Polygon coordinates", "help": "Semicolon-separated list of coordinate pairs (x,y). Example: '0,0;100,0;100,100;0,100' for a square", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "target_coordinate_system", "argument": null, "type": "text", "label": "Target coordinate system", "help": "The coordinate system of the polygon", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": "global", "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "filter_table_bool", "argument": null, "type": "boolean", "label": "Filter table?", "help": "Filter tables to only include tables annotating elements in the query result", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": true, "truevalue": "True", "falsevalue": "False"}, {"model_class": "BooleanToolParameter", "name": "clip_shapes_bool", "argument": null, "type": "boolean", "label": "Clip shapes?", "help": "If True, shapes are clipped to the polygon. This behavior is implemented only when querying polygons/multipolygons or circles, and it is ignored for other types of elements (images, labels, points). Importantly, when clipping is enabled, the circles will be converted to polygons before the clipping. This may affect downstream operations that rely on the circle radius or on performance, so it is recommended to disable clipping when querying circles or when querying a SpatialData object that contains circles.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "True", "falsevalue": "False"}]}, {"model_class": "ConditionalWhen", "value": "get_values", "inputs": [{"model_class": "TextToolParameter", "name": "value_key", "argument": null, "type": "text", "label": "Value key", "help": "Column name(s) to retrieve values from", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "element_name", "argument": null, "type": "text", "label": "Element name", "help": "Name of the element to get values from", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "table_name", "argument": null, "type": "text", "label": "Table name (optional)", "help": "Name of table containing the value_key", "help_format": "html", "refresh_