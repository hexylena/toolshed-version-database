es element name", "help": "Name of the element of spatialdata containing values to aggregate", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "by_element", "argument": null, "type": "text", "label": "Regions element name", "help": "Name of the element defining regions to aggregate by", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "value_key", "argument": null, "type": "text", "label": "Value key (optional)", "help": "Column name containing values to aggregate. Leave empty to count occurrences", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "SelectToolParameter", "name": "agg_func", "argument": null, "type": "select", "label": "Aggregation function", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "sum", "options": [["Sum", "sum", false], ["Mean", "mean", false], ["Count", "count", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "TextToolParameter", "name": "target_coordinate_system", "argument": null, "type": "text", "label": "Target coordinate system", "help": "", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": "global", "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "fractions_bool", "argument": null, "type": "boolean", "label": "Adjust for partial overlap?", "help": "If True, values are weighted by overlap fraction", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "True", "falsevalue": "False"}, {"model_class": "TextToolParameter", "name": "region_key", "argument": null, "type": "text", "label": "Region key", "help": "Name for the region column in output table", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "region", "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "instance_key", "argument": null, "type": "text", "label": "Instance key", "help": "Name for the instance ID column in output table", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "instance_id", "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "table_name", "argument": null, "type": "text", "label": "Table name (optional)", "help": "Table containing the value_key", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": "", "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "deepcopy_bool", "argument": null, "type": "boolean", "label": "Deep copy shapes?", "help": "Whether to deepcopy shapes in result", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": true, "truevalue": "True", "falsevalue": "False"}, {"model_class": "IntegerToolParameter", "name": "buffer_resolution", "argument": null, "type": "integer", "label": "Resolution", "help": " A higher value results in a more accurate representation of the circle, but also in a more complex polygon and computation.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "16", "area": false, "datalist": []}]}, {"model_class": "ConditionalWhen", "value": "map_raster", "inputs": [{"model_class": "TextToolParameter", "name": "element_name", "argument": null, "type": "text", "label": "Raster element name", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "func_name", "argument": null, "type": "text", "label": "Function name", "help": "Name of numpy/scipy function to apply (e.g., 'numpy.mean')", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "blockwise_bool", "argument": null, "type": "boolean", "label": "Process blockwise?", "help": "If True, func will be distributed with dask.array.map_overlap() or dask.array.map_blocks(), otherwise func is applied to the full data. If False, depth and chunks are ignored.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": true, "truevalue": "True", "falsevalue": "False"}, {"model_class": "IntegerToolParameter", "name": "depth", "argument": null, "type": "integer", "label": "Overlap between chunks (optional)", "help": "the number of elements that each chunk should share with its neighboring chunks", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "chunks", "argument": null, "type": "text", "label": "Chunks (optional)", "help": "Chunk shape of resulting blocks if the callable does not preserve the data shape. Format: nested tuples like '((1,),(100,),(100,))' for shape (1,100,100). Passed to dask.array.map_overlap() or dask.array.map_blocks(). Ignored if blockwise is False.", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "c_coords", "argument": null, "type": "text", "label": "Channel coordinates (optional)", "help": "Comma-separated channel coordinates for output data (integers or strings). If not provided, input channel coordinates are used. Required if func changes number of channels.", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "dims", "argument": null, "type": "text", "label": "Output dimensions (optional)", "help": "Comma-separated dimensions of output data (e.g., 'c,y,x' or 'y,x'). If not provided, input dimensions are used. Must be specified if callable changes dimensions.", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "transformations", "argument": null, "type": "text", "label": "Transformations JSON (optional)", "help": "JSON string for output transformations. If not provided, input transformations are copied. Should be specified if callable changes transformations.", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "relabel_bool", "argument": null, "type": "boolean", "label": "Relabel blocks?", "help": "Whether to relabel blocks of output data. Ignored when output is not a labels layer. Recommended if func returns labels not unique across chunks.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": true, "truevalue": "True", "falsevalue": "False"}]}, {"model_class": "ConditionalWhen", "value": "unpad_raster", "inputs": [{"model_class": "TextToolParameter", "name": "element_name", "argument": null, "type": "text", "label": "Raster element name", "help": "Name of raster element to unpad", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}]}, {"model_class": "ConditionalWhen", "value": "are_extents_equal", "inputs": [{"model_class": "TextToolParameter", "name": "element1_name", "argument": null, "type": "text", "label": "First element name", "help": "", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "element2_name", "argument": null, "type": "text", "label": "Second element name", "help": "", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "coordinate_system", "argument": null, "type": "text", "label": "Coordinate system", "help": "", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": "global", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "atol", "argument": null, "type": "float", "label": "Absolute tolerance", "help": "", "help_format": "html", "refresh_on_change": false, "min": null, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.1", "area": false, "datalist": []}]}, {"model_class": "ConditionalWhen", "value": "sanitize_table", "inputs": [{"model_class": "TextToolParameter", "name": "table_name", "argument": null, "type": "text", "label": "Table name", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "table", "area": false, "datalist": []}]}, {"model_class": "ConditionalWhen", "value": "export_table", "inputs": [{"model_class": "TextToolParameter", "name": "table_name", "argument": null, "