{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/upsetplot/rcx_upsetplot/1.4.0+galaxy0", "name": "upset plot", "version": "1.4.0+galaxy0", "description": "Upset plot visualization tool using UpSetR", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "upsetplot", "owner": "iuc", "changeset_revision": "ec6141f6e5cb", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "input_data", "argument": null, "type": "data", "label": "Input Data Table", "help": "Input file in a tabular/tsv/csv/parquet format containing the data for the UpSet plot.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["csv", "tsv", "tabular", "parquet"], "edam": {"edam_formats": ["format_3475", "format_3475", "format_3475", "format_2333"], "edam_data": ["data_0006", "data_0006", "data_0006", "data_0006"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "SelectToolParameter", "name": "order_by", "argument": null, "type": "select", "label": "Sort Bars By", "help": "Choose how to sort the bars in the UpSet plot: by frequency (largest frequency first), degree (largest overlap first), or both.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "freq", "options": [["Frequency", "freq", true], ["Degree", "degree", false], ["Both", "both", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "IntegerToolParameter", "name": "nsets", "argument": null, "type": "integer", "label": "Number of Sets to Include", "help": "Specify the number of sets to include in the plot. The largest sets will be visualized first. Default is 5.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": 100, "optional": false, "hidden": false, "is_dynamic": false, "value": "5", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "nintersects", "argument": null, "type": "integer", "label": "Number of Intersections to Plot", "help": "Specify the number of intersections to display in the plot. If set to 0, all intersections will be plotted.", "help_format": "html", "refresh_on_change": false, "min": null, "max": null, "optional": true, "hidden": false, "is_dynamic": false, "value": "0", "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "group_by", "argument": null, "type": "boolean", "label": "Group Bars by Sets", "help": "Enable this option to group bars for each set based on their set size. Otherwise, bars will be grouped by degree.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "sets", "falsevalue": "degree"}, {"model_class": "BooleanToolParameter", "name": "empty_intersections", "argument": null, "type": "boolean", "label": "Include Empty Intersections", "help": "Enable this option to include empty intersections in the plot, up to the limit of the number of intersections. By default, empty intersections are omitted.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "TRUE", "falsevalue": "NULL"}, {"model_class": "IntegerToolParameter", "name": "cutoff", "argument": null, "type": "integer", "label": "Intersection Size Cutoff", "help": "Specify a threshold for filtering intersections. Only intersections with a size greater than or equal to this value will be included in the plot. Leave empty to include all intersections.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "export_R_script", "argument": null, "type": "boolean", "label": "Export R Script for Reproducibility", "help": "Enable this option to export the R script used to generate the plot. This allows you to reproduce the analysis offline. Note that file paths and dependencies must be managed manually.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "TRUE", "falsevalue": "FALSE"}], "outputs": [{"model_class": "ToolOutput", "name": "upsetplot", "format": "png", "label": "Upset plot on ${on_string}", "hidden": false, "output_type": "data", "format_source": null, "default_identifier_source": "None", "metadata_source": null, "parent": null, "count": 1, "from_work_dir": "upsetplot.png", "edam_format": "format_3603", "edam_data": "data_2968", "discover_datasets": []}, {"model_class": "ToolOutput", "name": "script", "format": "txt", "label": "R script", "hidden": false, "output_type": "data", "format_source": null, "default_identifier_source": "None", "metadata_source": null, "parent": null, "count": 1, "from_work_dir": null, "edam_format": "format_2330", "edam_data": "data_0006", "discover_datasets": []}], "panel_section_id": "graph_display_data", "panel_section_name": "Graph/Display Data", "form_style": "regular"}