{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/page_dewarp/page_dewarp/0.2.7+galaxy0", "name": "Page dewarp", "version": "0.2.7+galaxy0", "description": "flatten and threshold warped document images", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "versions": ["0.2.7+galaxy0"], "hidden_versions": [], "tool_shed_repository": {"name": "page_dewarp", "owner": "iuc", "changeset_revision": "b47beced512f", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "Conditional", "name": "mode", "type": "conditional", "cases": [{"model_class": "ConditionalWhen", "value": "batch", "inputs": [{"model_class": "DataToolParameter", "name": "input_images", "argument": null, "type": "data", "label": "Input images", "help": "Select one or more datasets, or a list collection. All selected images are dewarped in one job and returned as a list collection.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["jpg", "png", "tiff", "bmp"], "edam": {"edam_formats": ["format_3579", "format_3603", "format_3591", "format_3592"], "edam_data": ["data_2968", "data_2968", "data_2968", "data_2968"]}, "multiple": true, "min": null, "max": null, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}]}, {"model_class": "ConditionalWhen", "value": "single", "inputs": [{"model_class": "DataToolParameter", "name": "input_image", "argument": null, "type": "data", "label": "Input image", "help": "A single document page image. To run on many images at once, switch to batch mode or map this tool over a collection.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["jpg", "png", "tiff", "bmp"], "edam": {"edam_formats": ["format_3579", "format_3603", "format_3591", "format_3592"], "edam_data": ["data_2968", "data_2968", "data_2968", "data_2968"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}]}], "test_param": {"model_class": "SelectToolParameter", "name": "processing", "argument": null, "type": "select", "label": "Processing mode", "help": "Batch dewarps several images in a single page-dewarp invocation, amortising startup cost - recommended when you already have a collection or a handful of images. Per-image dewarps a single dataset; map the tool over a collection if you want one job per image (gives per-image error isolation and cluster parallelism).", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": "batch", "options": [["Batch - many images in one job (collection-friendly)", "batch", true], ["Per-image - one image per job", "single", false]], "display": null, "multiple": false, "textable": false}}, {"model_class": "Section", "name": "output_options", "type": "section", "title": "Output options", "help": null, "expanded": false, "inputs": [{"model_class": "FloatToolParameter", "name": "output_zoom", "argument": "--output-zoom", "type": "float", "label": "Output zoom factor", "help": "Zoom of output relative to original image. 2.0 roughly doubles the dimensions.", "help_format": "html", "refresh_on_change": false, "min": 0.1, "max": 10.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "1.0", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "output_dpi", "argument": "--output-dpi", "type": "integer", "label": "Output PNG DPI", "help": "Stated DPI metadata of the output PNG (does not affect appearance).", "help_format": "html", "refresh_on_change": false, "min": 50, "max": 1200, "optional": false, "hidden": false, "is_dynamic": false, "value": "300", "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "no_binary", "argument": "--no-binary", "type": "boolean", "label": "Disable binary thresholding", "help": "If enabled, output the remapped grayscale image without adaptive thresholding.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "--no-binary 1", "falsevalue": "--no-binary 0"}]}, {"model_class": "Section", "name": "optim", "type": "section", "title": "Optimisation options", "help": null, "expanded": false, "inputs": [{"model_class": "SelectToolParameter", "name": "method", "argument": "--method", "type": "select", "label": "Optimisation method", "help": "auto picks L-BFGS-B if JAX is available, otherwise Powell.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "auto", "options": [["auto", "auto", true], ["L-BFGS-B", "L-BFGS-B", false], ["Powell", "Powell", false], ["Nelder-Mead", "Nelder-Mead", false], ["CG", "CG", false], ["BFGS", "BFGS", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "IntegerToolParameter", "name": "max_iter", "argument": "--max-iter", "type": "integer", "label": "Maximum iterations", "help": "Maximum optimiser iterations. Set to 1 for a fast draft preview.", "help_format": "html", "refresh_on_change": false, "min": 1, "max": 10000000, "optional": false, "hidden": false, "is_dynamic": false, "value": "600000", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "max_corrections", "argument": "--max-corrections", "type": "integer", "label": "L-BFGS-B max corrections", "help": "Maximum corrections used to approximate the inverse Hessian (L-BFGS-B only).", "help_format": "html", "refresh_on_change": false, "min": 1, "max": 1000, "optional": false, "hidden": false, "is_dynamic": false, "value": "100", "area": false, "datalist": []}]}, {"model_class": "Section", "name": "page_detection", "type": "section", "title": "Page detection", "help": null, "expanded": false, "inputs": [{"model_class": "IntegerToolParameter",