ax": 10.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "1.5", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "max_text_thickness", "argument": "--max-text-thickness", "type": "integer", "label": "Maximum text contour thickness (reduced px)", "help": "Contours thicker than this are filtered out.", "help_format": "html", "refresh_on_change": false, "min": 1, "max": 100, "optional": false, "hidden": false, "is_dynamic": false, "value": "10", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "adaptive_winsz", "argument": "--adaptive-winsz", "type": "integer", "label": "Adaptive threshold window size", "help": "Window size for adaptive thresholding. Must be an odd number.", "help_format": "html", "refresh_on_change": false, "min": 3, "max": 999, "optional": false, "hidden": false, "is_dynamic": false, "value": "55", "area": false, "datalist": []}]}, {"model_class": "Section", "name": "span_edge", "type": "section", "title": "Span and edge detection", "help": null, "expanded": false, "inputs": [{"model_class": "IntegerToolParameter", "name": "min_span_width", "argument": "--min-span-width", "type": "integer", "label": "Minimum span width (reduced px)", "help": "", "help_format": "html", "refresh_on_change": false, "min": 1, "max": 500, "optional": false, "hidden": false, "is_dynamic": false, "value": "30", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "span_spacing", "argument": "--span-spacing", "type": "integer", "label": "Span sampling spacing (reduced px)", "help": "", "help_format": "html", "refresh_on_change": false, "min": 1, "max": 500, "optional": false, "hidden": false, "is_dynamic": false, "value": "20", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "max_edge_overlap", "argument": "--max-edge-overlap", "type": "float", "label": "Maximum edge overlap (reduced px)", "help": "Maximum horizontal overlap of contours w