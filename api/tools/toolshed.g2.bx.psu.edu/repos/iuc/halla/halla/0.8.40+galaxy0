html", "refresh_on_change": false, "min": 0, "max": null, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "SelectToolParameter", "name": "pdist_metric", "argument": "--pdist_metric", "type": "select", "label": "Distance/similarity metric", "help": "default: spearman for continuous data, If there is at least one categorical variable in either dataset, HAllA will shift to Normalized Mutual Information (NMI) as an alternative similarity measure.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "spearman", "options": [["Spearman", "spearman", true], ["Pearson", "pearson", false], ["Distance correlation", "dcor", false], ["mutual information", "mi", false], ["normalized mutual information", "nmi", false], ["xi correlation", "xicor", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "BooleanToolParameter", "name": "sim2dist_disable_abs", "argument": "--sim2dist_disable_abs", "type": "boolean", "label": "Hierarchical clustering - disable setting similarity scores as absolute when computing distance", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "--sim2dist_disable_abs", "falsevalue": ""}, {"model_class": "SelectToolParameter", "name": "linkage_method", "argument": "--linkage_method", "type": "select", "label": "Hierarchical clustering linkage method", "help": "see help below", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "average", "options": [["single", "single", false], ["complete", "complete", false], ["average", "average", true], ["weighted", "weighted", false], ["centroid", "centroid", false], ["median", "median", false], ["ward", "ward", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "SelectToolParameter", "name": "permute_func", "argument": "--permute_func", "type": "select", "label": "P-value approximation function", "help": " in the p-value permutation test", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "gpd", "options": [["gdp", "gpd", false], ["ecdf", "ecdf", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "IntegerToolParameter", "name": "permute_iters", "argument": "--permute_iters", "type": "integer", "label": "Number of iterations in the p-value permutation test", "help": "", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "1000", "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "disable_permute_speedup", "argument": "--disable_permute_speedup", "type": "boolean", "label": "Do not break early in the permutation test if p-value is insignificant", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "--disable_permute_speedup", "falsevalue": ""}, {"model_class": "FloatToolParameter", "name": "fdr_alpha", "argument": "--fdr_alpha", "type": "float", "label": "FDR threshold", "help": "", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": 1.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.05", "area": false, "datalist": []}, {"model_class": "SelectToolParameter", "name": "fdr_method", "argument": "--fdr_method", "type": "select", "label": "FDR method", "help": "see help below", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "fdr_bh", "options": [["bonferroni: one-step correction", "bonferroni", false], ["sidak: one-step correction", "sidak", false], ["holm-sidak: ", "holm-sidak", false], ["holm: ", "holm", false], ["simes-hochberg: ", "simes-hochberg", false], ["hommel: ", "hommel", false], ["fdr_bh: Benjamini/Hochberg (non-negative)", "fdr_bh", true], ["fdr_by: Benjamini/Yekutieli (negative)", "fdr_by", false], ["fdr_tsbh: two stage fdr correction (non-negative)", "fdr_tsbh", false], ["fdr_tsbky: two stage fdr correction (non-negative)", "fdr_tsbky", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "FloatToolParameter", "name": "fnr_thresh", "argument": "--fnr_thresh", "type": "float", "label": "FNR threshold", "help": "", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": 1.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.05", "area": false, "datalist": []}, {"model_class": "SelectToolParameter", "name": "rank_cluster", "argument": "--rank_cluster", "type": "select", "label": "Procedure to rank cluster using the p-values within the cluster", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "best", "options": [["best", "best", true], ["average", "average", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "IntegerToolParameter", "name": "seed", "argument": "--seed", "type": "integer", "label": "Randomization seed", "help": "", "help_format": "html", "refresh_on_change": false, "min": null, "max": null, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "hallagram", "argument": "--hallagram", "type": "boolean", "label": "Generate hallagram", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": true, "truevalue": "--hallagram", "falsevalue": "--no_hallagram"}, {"model_class": "TextToolParameter", "name": "x_dataset_label", "argument": "--x_dataset_label", "type": "text", "label": "Hallagram/clustermap: label for X dataset", "help":