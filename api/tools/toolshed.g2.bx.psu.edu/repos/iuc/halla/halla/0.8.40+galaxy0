{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/halla/halla/0.8.40+galaxy0", "name": "HAllA", "version": "0.8.40+galaxy0", "description": "Hierarchical All-against-All association", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "halla", "owner": "iuc", "changeset_revision": "cafea02ae3e0", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "x", "argument": "-x", "type": "data", "label": "Dataset X", "help": "Tabular dataset with p features/rows and n samples/columns", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["tabular"], "edam": {"edam_formats": ["format_3475"], "edam_data": ["data_0006"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "DataToolParameter", "name": "y", "argument": "-y", "type": "data", "label": "Dataset Y", "help": "Tabular dataset with d features/rows and n samples/columns", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["tabular"], "edam": {"edam_formats": ["format_3475"], "edam_data": ["data_0006"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "BooleanToolParameter", "name": "alla", "argument": "--alla", "type": "boolean", "label": "Use AllA instead of HAllA", "help": "HAllA uses a hierarchical approach for block association discovery on top of an existing all-against-all (AllA) association matrix. Use this option to skip the block association step.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "--alla", "falsevalue": ""}, {"model_class": "FloatToolParameter", "name": "max_fre