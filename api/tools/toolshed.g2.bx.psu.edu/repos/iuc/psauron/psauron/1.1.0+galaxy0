{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/psauron/psauron/1.1.0+galaxy0", "name": "Psauron", "version": "1.1.0+galaxy0", "description": "Machine learning model for rapid assessment of protein coding gene annotation", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "psauron", "owner": "iuc", "changeset_revision": "085451872bcc", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "i", "argument": "-i", "type": "data", "label": "Input fasta", "help": "FASTA with spliced CDS sequence or protein sequence. A spliced CDS fasta can be created from a GTF/GFF and a reference FASTA by using gffread.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["fasta"], "edam": {"edam_formats": ["format_1929"], "edam_data": ["data_2044"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "IntegerToolParameter", "name": "minimum_length", "argument": "--minimum-length", "type": "integer", "label": "Exclude all proteins shorter than m amino acids", "help": "", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": true, "hidden": false, "is_dynamic": false, "value": "5", "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "exclude", "argument": "--exclude", "type": "text", "label": "Exclude any CDS where FASTA description contains given text (case invariant), e.g. hypothetical", "help": "", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": "None", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "inframe", "argument": "--inframe", "type": "float", "label": "Probability threshold used to determine final psauron score, in-frame, higher number decreases sensitivity and increases specificity, default=0.5", "help": "", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": 1.0, "optional": true, "hidden": false, "is_dynamic": false, "value": "0.5", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "outframe", "argument": "--outframe", "type": "float", "label": "Probability threshold used to determine final psauron score, out-of-frame, higher number increases sensitivity and decreases specificity, default=0.5", "help": "", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": 1.0, "optional": true, "hidden": false, "is_dynamic": false, "value": "0.5", "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "s", "argument": "-s", "type": "boolean", "label": "Score only the in-frame CDS, which may lower accuracy of the model", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "-s", "falsevalue": ""}, {"model_class": "BooleanToolParameter", "name": "p", "argument": "-p", "type": "boolean", "label": "Set to Yes if your FASTA contains amino acid protein sequence, which may lower accuracy of the model", "help": "", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "-p", "falsevalue": ""}], "outputs": [{"model_class": "ToolOutput", "name": "psauron_score_file", "format": "csv", "label": "${tool.name} on ${on_string}: csv with scores for all reading frames", "hidden": false, "output_type": "data", "format_source": null, "default_identifier_source": "None", "metadata_source": null, "parent": null, "count": 1, "from_work_dir": null, "edam_format": "format_3475", "edam_data": "data_0006", "discover_datasets": []}], "panel_section_id": "annotation", "panel_section_name": "Annotation", "form_style": "regular"}