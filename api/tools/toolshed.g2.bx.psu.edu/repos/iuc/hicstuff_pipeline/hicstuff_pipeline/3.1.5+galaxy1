{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/hicstuff_pipeline/hicstuff_pipeline/3.2.4+galaxy0", "name": "hicstuff full pipeline", "version": "3.2.4+galaxy0", "description": "generates a Hi-C contact matrix", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "hicstuff_pipeline", "owner": "iuc", "changeset_revision": "7ffc3748ffde", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "genome", "argument": null, "type": "data", "label": "Genome fasta file", "help": "", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["fasta", "fasta.gz"], "edam": {"edam_formats": ["format_1929", "format_1929"], "edam_data": ["data_2044", "data_2044"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "Conditional", "name": "paired_cond", "type": "conditional", "cases": [{"model_class": "ConditionalWhen", "value": "paired", "inputs": [{"model_class": "DataCollectionToolParameter", "name": "reads", "argument": null, "type": "data_collection", "label": "Paired reads", "help": "", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "collection_types": ["paired"], "fields": null, "column_definitions": null, "extensions": ["fastqsanger", "fastqsanger.gz"], "multiple": false, "options": {"hda": [], "hdca": [], "dce": []}, "tag": null}]}, {"model_class": "ConditionalWhen", "value": "separate", "inputs": [{"model_class": "DataToolParameter", "name": "forward_reads", "argument": null, "type": "data", "label": "Forward reads", "help": "", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["fastqsanger", "fastqsanger.gz"], "eda