{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/fastspar_pvalues/fastspar_pvalues/1.0.0+galaxy0", "name": "FastSpar: estimate p-values", "version": "1.0.0+galaxy0", "description": "Bootstrap-based estimation of p-values from FastSpar correlations", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [{"value": "FastSpar", "type": "bio.tools"}], "tool_shed_repository": {"name": "fastspar_pvalues", "owner": "iuc", "changeset_revision": "7ff1304e12aa", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "otu_table", "argument": "--otu_table", "type": "data", "label": "Input OTU table", "help": "The table must contain absolute OTU counts in plain tabular (TSV) format, with OTUs as rows and samples as columns. Do not include any metadata rows or columns.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["tabular"], "edam": {"edam_formats": ["format_3475"], "edam_data": ["data_0006"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "Conditional", "name": "correlation", "type": "conditional", "cases": [{"model_class": "ConditionalWhen", "value": "new", "inputs": []}, {"model_class": "ConditionalWhen", "value": "original", "inputs": [{"model_class": "DataToolParameter", "name": "input_file", "argument": "--correlation", "type": "data", "label": "Correlation table", "help": "The correlation matrix generated by the original FastSpar analysis.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["tabular"], "edam": {"edam_formats": ["format_3475"], "edam_data": ["data_0006"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}]}], "test_param": {"model_class": "SelectToolParameter", "name": "select", "argument": null, "type": "select", "label": "Tested correlation matrix", "help": "For meaningful p-values, the parameters used during bootstrapped correlation estimation should be identical to those used for the FastSpar run which produced the correlation matrix. <br>For your convenience you can choose to calculate the correlation matrix here. In that case the seed used for the calculation is the same one used for generating the bootstrapped samples.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": "new", "options": [["Recalculate the correlation matrix", "new", false], ["Use an existing correlation matrix", "original", false]], "display": null, "multiple": false, "textable": false}}, {"model_class": "IntegerToolParameter", "name": "number", "argument": "--number", "type": "integer", "label": "Number of bootstrap samples", "help": "Recommended minimum: 1000 bootstrap samples for robust estimation.", "help_format": "html", "refresh_on_change": false, "min": 10, "max": 10000, "optional": false, "hidden": false, "is_dynamic": false, "value": "1000", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "iterations", "argument": "--iterations", "type": "integer", "label": "Number of iterations", "help": "Rounds of SparCC correlation estimation.", "help_format": "html", "refresh_on_change": false, "min": 1, "max": 1000, "optional": false, "hidden": false, "is_dynamic": false, "value": "50", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "exclude_iterations", "argument": "--exclude_iterations", "type": "integer", "label": "Number of exclusion iterations", "help": "The number of times highly correlated OTU pairs are excluded.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": 100, "optional": false, "hidden": false, "is_dynamic": false, "value": "10", "area": false, "datalist": []}, {"model_class": "FloatToolParameter", "name": "threshold", "argument": "--threshold", "type": "float", "label": "Exclusion threshold", "help": "Correlation strength above which to exclude OTU pairs.", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": 1.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.1", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "seed", "argument": "--seed", "type": "integer", "label": "Seed to ensure reproducibility of bootstrapped samples.", "help": "", "help_format": "html", "refresh_on_change": false, "min": null, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "1", "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "pseudo", "argument": "--pseudo", "type": "boolean", "label": "Use pseudo p-values", "help": "If selected, pseudo p-values are calculated instead of exact p-values. This can provide faster estimates but may be less precise.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "--pseudo", "falsevalue": ""}], "outputs": [{"model_class": "ToolOutput", "name": "output_correlation", "format": "tabular", "label": "${tool.name} on ${on_string}: median_correlation.tsv", "hidden": false, "output_type": "data", "format_source": null, "default_identifier_source": "None", "metadata_source": null, "parent": null, "count": 1, "from_work_dir": null, "edam_format": "format_3475", "edam_data": "data_0006", "discover_datasets": []}, {"model_class": "ToolOutput", "name": "output_covariance", "format": "tabular", "label": "${tool.name} on ${on_string}: median_covariance.tsv", "hidden": false, "output_type": "data", "format_source": null, "default_identifier_source": "None", "metadata_source": null, "parent": null, "count": 1, "from_work_dir": null, "edam_format": "format_3475", "edam_data": "data_0006", "discover_datasets": []}, {"model_class": "Too