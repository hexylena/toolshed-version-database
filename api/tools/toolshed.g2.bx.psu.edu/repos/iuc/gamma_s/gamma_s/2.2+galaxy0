{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/iuc/gamma_s/gamma_s/2.2+galaxy0", "name": "GAMMA-S", "version": "2.2+galaxy0", "description": "finds gene matches in microbial genomic data using nucleotide identity", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "gamma_s", "owner": "iuc", "changeset_revision": "f6f0b5f3066e", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "input_fasta", "argument": null, "type": "data", "label": "Input FASTA file", "help": "a genome or assembly in FASTA format", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["fasta"], "edam": {"edam_formats": ["format_1929"], "edam_data": ["data_2044"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "DataToolParameter", "name": "input_db", "argument": null, "type": "data", "label": "Database to screen against", "help": "a multifasta database of the coding sequence of genes.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["fasta"], "edam": {"edam_formats": ["format_1929"], "edam_data": ["data_2044"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "BooleanToolParameter", "name": "all", "argument": "--all", "type": "boolean", "label": "Include all gene matches", "help": "Returns all (including overlapping) gene matches", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": false, "truevalue": "-a", "falsevalue": ""}, {"model_class": "IntegerToolParameter", "name": "identity", "argument": "--identity", "type": "integer", "label": "Nucleotide sequence identity", "help":