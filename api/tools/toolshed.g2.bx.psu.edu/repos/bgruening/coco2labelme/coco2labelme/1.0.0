{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/bgruening/coco2labelme/coco2labelme/1.0.1", "name": "COCO to LabelMe JSON Converter", "version": "1.0.1", "description": "Convert COCO annotation files into LabelMe-compatible JSON format", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "versions": ["1.0.1"], "hidden_versions": [], "tool_shed_repository": {"name": "coco2labelme", "owner": "bgruening", "changeset_revision": "06a8da74643e", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "coco_file", "argument": null, "type": "data", "label": "COCO annotation file", "help": "JSON file in COCO format containing images, annotations, and categories.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["json"], "edam": {"edam_formats": ["format_3464"], "edam_data": ["data_0006"]}, "multiple": true, "min": null, "max": null, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "Conditional", "name": "image_path_mode", "type": "conditional", "cases": [{"model_class": "ConditionalWhen", "value": "simple", "inputs": []}, {"model_class": "ConditionalWhen", "value": "custom", "inputs": [{"model_class": "TextToolParameter", "name": "custom_image_path", "argument": null, "type": "text", "label": "Custom base path", "help": "Base directory prepended to each image filename in 'imagePath' (e.g. '../images' \u2192 '../images/photo.jpg').", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": "../images", "area": false, "datalist": []}]}], "test_param": {"model_class": "SelectToolParameter", "name": "path_mode", "argument": null, "type": "select", "label": "Image path mode", "help": "Controls how the 'imagePath' field is written in each output JSON. Choose the mode t