{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/tduigou/parameters_maystro_workflow_2/parameters_maystro_workflow_2/0.1.0", "name": "Workflow-2 Parameters Maystro", "version": "0.1.0", "description": "Store parameters of workflow-2 to be used again", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "parameters_maystro_workflow_2", "owner": "tduigou", "changeset_revision": "c6708a220f23", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "SelectToolParameter", "name": "DnaOptimizationProblemClass", "argument": null, "type": "select", "label": "DnaOptimizationProblem Calss", "help": "select the assambly class", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": "DnaOptimizationProblem", "options": [["DnaOptimizationProblem", "DnaOptimizationProblem", true], ["CircularDnaOptimizationProblem", "CircularDnaOptimizationProblem", false]], "display": null, "multiple": false, "textable": false}, {"model_class": "TextToolParameter", "name": "avoid_patterns", "argument": null, "type": "text", "label": "Avoid Patterns (one per line)", "help": "", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": true, "datalist": []}, {"model_class": "TextToolParameter", "name": "hairpin_constraints", "argument": null, "type": "text", "label": "Hairpins Constraints", "help": "e.g. (you can add others Hairpins Constraints on a new line): stem_size=20, hairpin_window=200", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "area": true, "datalist": []}, {"model_class": "TextToolParameter", "name": "gc_constraints", "argument": null, "type": "text", "label": "Enforce GC Content Constraints", "help": "e.g. (you can add others Enforce GC Content C