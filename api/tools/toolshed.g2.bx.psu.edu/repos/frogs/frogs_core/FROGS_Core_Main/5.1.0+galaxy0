ut type", "help": "Sample files can be provided either as a single TAR archive or as separate files per sample (one file each).", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": "archive", "options": [["TAR Archive", "archive", true], ["Files per samples", "files_per_samples", false]], "display": null, "multiple": false, "textable": false}}, {"model_class": "IntegerToolParameter", "name": "min_amplicon_size", "argument": "--min-amplicon-size", "type": "integer", "label": "Minimum amplicon length", "help": "The minimum length of the amplicons (including primers).", "help_format": "html", "refresh_on_change": false, "min": null, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "max_amplicon_size", "argument": "--max-amplicon-size", "type": "integer", "label": "Maximum amplicon length", "help": "The maximum length of the amplicons (including primers).", "help_format": "html", "refresh_on_change": false, "min": null, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "five_prim_primer", "argument": "--five-prim-primer", "type": "text", "label": "5' primer", "help": "Enter the 5' primer sequence. Wildcards are allowed. The sequence must be provided in 5' \u2192 3' orientation.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "area": false, "datalist": []}, {"model_class": "TextToolParameter", "name": "three_prim_primer", "argument": "--three-prim-primer", "type": "text", "label": "3' primer", "help": "Enter the 3' primer sequence. Wildcards are allowed. The sequence must be provided in 5' \u2192 3' orientation.", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dyna