{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/ecology/population_genomics_vcf_filtering/population_genomics_vcf_filtering/0.1.0", "name": "VCF filtering", "version": "0.1.0", "description": "of individuals and variants", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "population_genomics_vcf_filtering", "owner": "ecology", "changeset_revision": "ba40ff83be36", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "vcf_input", "argument": null, "type": "data", "label": "VCF file", "help": "File containing SNP data in VCF format. You can upload a simple file, multiple files or a dataset collection.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["vcf"], "edam": {"edam_formats": ["format_3016"], "edam_data": ["data_0006"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "SelectToolParameter", "name": "filter_order", "argument": null, "type": "select", "label": "Select your filters in the order you wish to apply them", "help": "Only the selected filters will be applied, in the exact order chosen here.", "help_format": "html", "refresh_on_change": false, "optional": true, "hidden": false, "is_dynamic": false, "value": null, "options": [["A: Individuals with missing data", "A", false], ["B: Loci with missing data", "B", false], ["C: Genotype quality (GQ)", "C", false], ["D: Depth coverage (DP)", "D", false], ["E: Biallelic SNPs only", "E", false], ["F: Minor allele count (MAC)", "F", false], ["G: Heterozygosity", "G", false]], "display": "checkboxes", "multiple": true, "textable": false}, {"model_class": "Section", "name": "filter_ind_missing_data", "type": "section", "title": "[A] Individuals with missing data", "help": null, "expanded": false, "inputs": [{"model_class": "FloatToolParameter", "name": "MAX_MISSING_IND", "argument": null, "type": "float", "label": "Maximum missing data per individual (MAX_MISSING_IND)", "help": "Maximum fraction of missing genotypes allowed per individual.", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": 1.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.2", "area": false, "datalist": []}]}, {"model_class": "Section", "name": "filter_loci_missing", "type": "section", "title": "[B] Loci with missing data", "help": null, "expanded": false, "inputs": [{"model_class": "FloatToolParameter", "name": "MAX_MISSING_LOCI", "argument": null, "type": "float", "label": "Maximum missing data per locus (MAX_MISSING_LOCI)", "help": "Maximum fraction of missing genotypes allowed per locus.", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": 1.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.2", "area": false, "datalist": []}]}, {"model_class": "Section", "name": "filter_GQ", "type": "section", "title": "[C] Genotype quality (GQ)", "help": null, "expanded": false, "inputs": [{"model_class": "IntegerToolParameter", "name": "MIN_GQ", "argument": null, "type": "integer", "label": "GQ minimum", "help": "Genotypes with a GQ below this value will be set to missing.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "20", "area": false, "datalist": []}]}, {"model_class": "Section", "name": "filter_DP", "type": "section", "title": "[D] Depth coverage (DP)", "help": null, "expanded": false, "inputs": [{"model_class": "IntegerToolParameter", "name": "MIN_DP", "argument": null, "type": "integer", "label": "Minimum read depth (MIN_DP)", "help": "Minimum read depth (DP) per genotype required to retain it.                    Typical values depend on sequencing coverage: 1-5 for permissive filtering, 10-20 for standard filtering, and >=30 for stringent filtering.", "help_format": "html", "refresh_on_change": false, "min": 1, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "6", "area": false, "datalist": []}]}, {"model_class": "Section", "name": "filter_mac", "type": "section", "title": "[F] Minor allele count (MAC)", "help": null, "expanded": false, "inputs": [{"model_class": "IntegerToolParameter", "name": "MAC", "argument": null, "type": "integer", "label": "Minimum minor allele count per SNP (MIN_MAC)", "help": "Minimum number of minor alleles required for a locus to be retained.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "2", "area": false, "datalist": []}]}, {"model_class": "Section", "name": "filter_het", "type": "section", "title": "[G] Heterozygosity", "help": null, "expanded": false, "inputs": [{"model_class": "FloatToolParameter", "name": "MAX_Ho", "argument": null, "type": "float", "label": "Maximum observed heterozygosity per SNP", "help": "Maximum proportion of observed heterozygotes allowed to retain a variant. Used to detect paralogues and genotyping errors.", "help_format": "html", "refresh_on_change": false, "min": 0.0, "max": 1.0, "optional": false, "hidden": false, "is_dynamic": false, "value": "0.6", "area": false, "datalist": []}]}], "outputs": [{"model_class": "ToolOutput", "name": "vcf_filtered", "format": "vcf", "label": "${tool.name}", "hidden": false, "output_type": "data", "format_source": null, "default_identifier_source": "None", "metadata_source": null, "parent": null, "count": 1, "from_work_dir": null, "edam_format": "format_3016", "edam_data": "data_0006", "discover_datasets": [{"discover_via": "pattern", "format": "vcf", "visible": true, "assign_primary_output": true, "directory": "vcf_filtered_directory", "recurse": false, "match_relative_path": false, "sort_key": "filename", "sort_comp": "lexical", "sort_reverse": false, "pattern": "(?P<designation>.*)\\.(?P<ext>[^\\._]+)?"}]}, {"model_class": "ToolOutput", "name": "summary", "format": "tabular", "label": "Filtering: Number of SNPs and individuals", "hidden": false, "output_type": "data", "format_source": null, "default_identifier_source": "None", "metadata_source": null, "parent": null, "count": 1, "from_work_dir": "summary/summary.tabular", "edam_format": "format_3475", "edam_data": "data_0006", "discover_datasets": []}], "panel_section_id": "population_genomics", "panel_section_name": "Population Genomics", "form_style": "regular"}