{"model_class": "Tool", "id": "toolshed.g2.bx.psu.edu/repos/ecology/population_genomics_vcf_subset/population_genomics_vcf_subset/0.1.0", "name": "Subsetting SNPs at random from a VCF file", "version": "0.1.0", "description": "given a chosen number of SNPs to use", "labels": [], "icon": null, "edam_operations": [], "edam_topics": [], "hidden": "", "is_workflow_compatible": true, "xrefs": [], "tool_shed_repository": {"name": "population_genomics_vcf_subset", "owner": "ecology", "changeset_revision": "b03ede8e228e", "tool_shed": "toolshed.g2.bx.psu.edu"}, "inputs": [{"model_class": "DataToolParameter", "name": "vcf_input", "argument": null, "type": "data", "label": "VCF file", "help": "File containing SNP data in VCF format. You can upload a simple file, multiple files or a dataset collection.", "help_format": "html", "refresh_on_change": true, "optional": false, "hidden": false, "is_dynamic": false, "value": null, "extensions": ["vcf"], "edam": {"edam_formats": ["format_3016"], "edam_data": ["data_0006"]}, "multiple": false, "options": {"dce": [], "ldda": [], "hda": [], "hdca": []}, "tag": null}, {"model_class": "IntegerToolParameter", "name": "SUBSET_SNPS_NB", "argument": null, "type": "integer", "label": "Number of SNPs chosen for a number of replicate VCF files per input VCF file", "help": "", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "1000", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "NB_REPLICATE_VCF", "argument": null, "type": "integer", "label": "Number of replicate VCF files", "help": "Number of replicate VCF files to create, each with a chosen subset of SNP.", "help_format": "html", "refresh_on_change": false, "min": 1, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "5", "area": false, "datalist": []}, {"model_class": "IntegerToolParameter", "name": "MIN_SNP_NB", "argument": null, "type": "integer", "label": "Minimum number of SNPs above which SNP subsetting is performed", "help": "To perform SNP subsampling without applying a threshold, enter 0.", "help_format": "html", "refresh_on_change": false, "min": 0, "max": null, "optional": false, "hidden": false, "is_dynamic": false, "value": "4000", "area": false, "datalist": []}, {"model_class": "BooleanToolParameter", "name": "polymorphic", "argument": null, "type": "boolean", "label": "Subset polymorphic SNPs only ?", "help": "MAC=2 filter is applicate to subset only polymorphic SNPs", "help_format": "html", "refresh_on_change": false, "optional": false, "hidden": false, "is_dynamic": false, "value": true, "truevalue": "true", "falsevalue": "false"}], "outputs": [{"model_class": "ToolOutputCollection", "name": "vcf_subsampled", "format": null, "label": "${tool.name}", "hidden": false, "output_type": "collection", "default_format": "vcf", "default_format_source": null, "default_metadata_source": null, "inherit_format": false, "inherit_metadata": false, "structure": {"collection_type": "list", "collection_type_source": null, "collection_type_from_rules": null, "structured_like": null, "discover_datasets": [{"discover_via": "pattern", "format": "vcf", "visible": false, "assign_primary_output": false, "directory": "vcf_subsampled", "recurse": false, "match_relative_path": false, "sort_key": "filename", "sort_comp": "lexical", "sort_reverse": false, "pattern": "(?P<designation>.*)\\.(?P<ext>[^\\._]+)?"}]}}], "panel_section_id": "population_genomics", "panel_section_name": "Population Genomics", "form_style": "regular"}